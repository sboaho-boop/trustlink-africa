generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  role          String    @default("customer")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workerProfile Worker?
  bookings      Booking[]
  reviewsGiven  Review[]  @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewTarget")
  savedWorkers  SavedWorker[]
  messagesSent  Message[] @relation("MessageSender")
  messagesReceived Message[] @relation("MessageReceiver")
}

model Worker {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName        String
  phone           String
  whatsapp        String?
  profilePicture  String?
  age             Int?
  gender          String?
  location        String
  region          String   @default("Greater Accra")
  languages       String   @default("English")

  serviceCategory String
  subServices     String   @default("")
  yearsExperience Int      @default(0)
  skills          String   @default("")
  availability    String   @default("full-time")
  availableDays   String   @default("mon,tue,wed,thu,fri")
  availableHours  String   @default("08:00-17:00")
  expectedMinPay  Int?
  expectedMaxPay  Int?
  bio             String?

  ghanaCardUrl    String?
  passportUrl     String?
  proofAddressUrl String?
  certificatesUrl String   @default("")
  references      String   @default("")

  verificationStatus String @default("pending")
  verifiedAt         DateTime?
  verifiedBy         String?
  rejectionReason    String?

  trustScore      Int      @default(0)
  idVerified      Boolean  @default(false)
  referencesChecked Boolean @default(false)
  employerConfirmed Boolean @default(false)
  totalJobs       Int      @default(0)

  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  ratingPunctuality Float @default(0)
  ratingQuality   Float    @default(0)
  ratingCommunication Float @default(0)
  ratingValue     Float    @default(0)

  isOnline        Boolean  @default(false)
  lastSeenAt      DateTime?

  bookings        Booking[]
  reviews          Review[]
  savedBy          SavedWorker[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Booking {
  id              String   @id @default(uuid())
  workerId        String
  worker          Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  customerId      String
  customer        User     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  serviceType     String
  description     String?
  date            DateTime
  duration        String
  location        String
  budget          Int
  notes           String?

  status          String   @default("pending")
  reminderSent    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Review {
  id          String   @id @default(uuid())
  workerId    String
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetId    String?
  target      User?    @relation("ReviewTarget", fields: [targetId], references: [id])

  rating              Int
  ratingPunctuality   Int   @default(0)
  ratingQuality       Int   @default(0)
  ratingCommunication Int   @default(0)
  comment             String?
  createdAt           DateTime @default(now())
}

model SavedWorker {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, workerId])
}

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}
